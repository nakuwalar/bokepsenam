---
// src/pages/index.astro
import Layout from '@layouts/BaseLayout.astro';
import VideoCard from '@components/VideoCard.astro';
import { getAllVideos } from '@utils/videoData';

export async function getStaticPaths() {
  return [{ params: {} }];
}

const allVideos = await getAllVideos();
allVideos.sort((a, b) => parseInt(b.id) - parseInt(a.id));

const currentVideos = allVideos; // Semua video akan ditampilkan di halaman utama

const allDomains = new Set<string>();
currentVideos.forEach(video => {
  try {
    allDomains.add(new URL(video.videoUrl).origin);
  } catch (e) {
    console.error(`[ERROR] URL video tidak valid di CSV untuk video ID ${video.id}:`, e);
  }
});
const preconnectDomains = Array.from(allDomains);
---

<Layout
  title="Video Portal - Koleksi Video Terbaru"
  description="Jelajahi koleksi video terbaru dan terpopuler dari berbagai kategori."
  preconnectDomains={preconnectDomains}
>
  <main class="home-page container">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <a itemprop="item" href="/">
            <span itemprop="name">Beranda</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
      </ol>
    </nav>

    <section class="hero-section">
      <h1>Selamat Datang di Portal Video Kami!</h1>
      <p>Temukan berbagai video menarik, dari alam hingga kuliner. Tonton sekarang juga!</p>
    </section>

    <section class="latest-videos-section">
      <h2>Video Terbaru</h2>
      <div class="video-grid">
        {currentVideos.length === 0 ? (
          <p class="no-videos">Belum ada video yang tersedia.</p>
        ) : (
          currentVideos.map((video) => (
            <VideoCard video={video} />
          ))
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    margin: 30px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .hero-section {
    text-align: center;
    margin-bottom: 40px;
    padding: 40px 20px;
    background: linear-gradient(to right, var(--primary-color), #0056b3);
    color: white;
    border-radius: 8px;
    box-shadow: var(--shadow-medium);
  }

  .hero-section h1 {
    font-size: clamp(2.5em, 5vw, 4em);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .hero-section p {
    font-size: clamp(1em, 2.5vw, 1.5em);
    opacity: 0.9;
  }

  .latest-videos-section {
    margin-top: 50px;
  }

  .latest-videos-section h2 {
    font-size: clamp(1.8em, 3.5vw, 2.5em);
    text-align: center;
    margin-bottom: 30px;
    color: #333;
    position: relative;
    padding-bottom: 10px;
  }

  .latest-videos-section h2::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 0;
    width: 60px;
    height: 4px;
    background-color: var(--accent-color);
    border-radius: 2px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
  }

  .no-videos {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1.2em;
    color: #999;
    padding: 50px 0;
  }

  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }
    .home-page {
      padding: 15px;
    }
    .hero-section {
      padding: 30px 15px;
    }
  }

  @media (max-width: 480px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>