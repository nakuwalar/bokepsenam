---
// src/pages/404.astro
import Layout from '@layouts/BaseLayout.astro';
---

<Layout title="Halaman Tidak Ditemukan" description="Maaf, halaman yang Anda cari tidak ditemukan.">
  <main class="not-found-page">
    <h1>404</h1>
    <p>Maaf, halaman yang Anda cari tidak dapat ditemukan.</p>
    <a href="/" class="home-button">Kembali ke Beranda</a>
  </main>
</Layout>

<style>
  .not-found-page {
    text-align: center;
    padding: 50px 20px;
    background-color: var(--background-color);
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .not-found-page h1 {
    font-size: 6em;
    color: var(--primary-color);
    margin-bottom: 10px;
  }

  .not-found-page p {
    font-size: 1.5em;
    color: var(--text-color);
    margin-bottom: 30px;
  }

  .home-button {
    display: inline-block;
    padding: 12px 25px;
    background-color: var(--primary-color);
    color: white;
    text-decoration: none;
    border-radius: 5px;
    font-size: 1.1em;
    transition: background-color 0.2s ease-in-out;
  }

  .home-button:hover {
    background-color: #0056b3;
  }
</style>