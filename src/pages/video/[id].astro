---
// src/pages/video/[id].astro
import Layout from '../layouts/BaseLayout.astro';
import { getAllVideos, getVideoById } from '../utils/videoData';
import { slugify } from '../utils/slugify';

export async function getStaticPaths() {
  const allVideos = await getAllVideos(); // Get all videos to generate paths
  console.log(`[DEBUG_VIDEO_DETAIL] Found ${allVideos.length} videos for detail pages.`);

  if (allVideos.length === 0) {
    console.warn(`[WARN_VIDEO_DETAIL] No videos found to generate detail pages. Check CSV.`);
    return [];
  }

  return allVideos.map((video) => ({
    params: { id: video.id }, // ID dari video akan menjadi parameter dinamis
    props: { videoId: video.id }, // Lewatkan ID video sebagai prop
  }));
}

const { videoId } = Astro.props; // Dapatkan videoId dari props

const video = await getVideoById(videoId); // Panggil fungsi baru

// Jika video tidak ditemukan (misalnya, ada ID di params tapi tidak ada di CSV)
if (!video) {
  console.error(`[ERROR_VIDEO_DETAIL] Video with ID ${videoId} not found.`);
  return Astro.redirect('/404'); // Atau tampilkan halaman error yang sesuai
}

// Untuk preconnect domain video
const preconnectDomains: string[] = [];
try {
  preconnectDomains.push(new URL(video.videoUrl).origin);
} catch (e) {
  console.error(`[ERROR] URL video tidak valid untuk ID ${video.id}:`, e);
}

// Breadcrumb data
const breadcrumbs = [
  { name: 'Beranda', url: '/' },
  { name: 'Kategori', url: '/kategori/' }, // Link ke halaman kategori (jika ada)
  { name: video.category, url: `/kategori/${slugify(video.category)}/` },
  { name: video.title, url: `/video/${video.id}/` },
];
---

<Layout
  title={video.title}
  description={video.description}
  canonicalUrl={`${import.meta.env.PUBLIC_SITE}/video/${video.id}/`}
  preconnectDomains={preconnectDomains}
>
  <main class="video-detail-page">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        {breadcrumbs.map((item, index) => (
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {index > 0 && <span class="separator">/</span>}
            {item.url ? (
              <a itemprop="item" href={item.url}>
                <span itemprop="name">{item.name}</span>
              </a>
            ) : (
              <span itemprop="name">{item.name}</span>
            )}
            <meta itemprop="position" content={(index + 1).toString()} />
          </li>
        ))}
      </ol>
    </nav>

    <section class="video-player-section">
      <h1 class="video-title">{video.title}</h1>
      <div class="video-wrapper">
        <iframe
          src={video.videoUrl}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          title={video.title}
          loading="lazy"
        ></iframe>
      </div>
      <div class="video-meta">
        <p class="video-category">Kategori: <a href={`/kategori/${slugify(video.category)}/`}>{video.category}</a></p>
        <p class="video-duration">Durasi: {video.duration}</p>
      </div>
      <div class="video-description">
        <h2>Deskripsi Video</h2>
        <p>{video.description}</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .video-detail-page {
    max-width: 900px;
    margin: 30px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .video-title {
    font-size: clamp(1.8em, 3vw, 2.5em);
    margin-bottom: 20px;
    color: var(--primary-color);
    text-align: center;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    margin-bottom: 25px;
    background-color: #000;
    border-radius: 8px;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
    font-size: 0.95em;
    color: #555;
  }

  .video-meta p {
    margin: 0;
  }

  .video-category a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 600;
  }

  .video-category a:hover {
    text-decoration: underline;
  }

  .video-description {
    border-top: 1px solid var(--border-color);
    padding-top: 25px;
  }

  .video-description h2 {
    font-size: 1.5em;
    color: #333;
    margin-top: 0;
    margin-bottom: 15px;
  }

  .video-description p {
    line-height: 1.8;
    color: #444;
  }

  .breadcrumb {
    margin-bottom: 20px;
    font-size: 0.9em;
    color: #666;
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
  }

  .breadcrumb a {
    color: var(--primary-color);
    text-decoration: none;
    white-space: nowrap;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .separator {
    margin: 0 8px;
    color: #999;
  }

  @media (max-width: 768px) {
    .video-detail-page {
      padding: 15px;
      margin: 20px auto;
    }
    .video-title {
      font-size: 2em;
    }
    .video-meta {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>
