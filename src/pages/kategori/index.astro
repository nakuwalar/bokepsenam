---
// src/pages/kategori/index.astro
import Layout from '@layouts/BaseLayout.astro';
import CategoryList from '@components/CategoryList.astro';
---

<Layout
  title="Semua Kategori Video"
  description="Daftar lengkap kategori video yang tersedia di portal kami."
>
  <main class="categories-index-page container">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <a itemprop="item" href="/">
            <span itemprop="name">Beranda</span>
          </a>
          <span class="separator">/</span>
          <meta itemprop="position" content="1" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <span itemprop="name">Kategori</span>
          <meta itemprop="position" content="2" />
        </li>
      </ol>
    </nav>

    <section class="categories-header">
      <h1>Jelajahi Berdasarkan Kategori</h1>
      <p>Temukan video favorit Anda dengan menelusuri kategori di bawah ini.</p>
    </section>

    <CategoryList />
  </main>
</Layout>

<style>
  .categories-index-page {
    margin: 30px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .categories-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 40px 20px;
    background: linear-gradient(to right, var(--secondary-color), #495057);
    color: white;
    border-radius: 8px;
    box-shadow: var(--shadow-medium);
  }

  .categories-header h1 {
    font-size: clamp(2em, 4vw, 3.5em);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .categories-header p {
    font-size: clamp(0.9em, 2vw, 1.2em);
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .categories-index-page {
      padding: 15px;
    }
    .categories-header {
      padding: 30px 15px;
    }
  }
</style>