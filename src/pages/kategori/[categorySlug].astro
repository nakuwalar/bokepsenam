---
// src/pages/kategori/[categorySlug].astro
import Layout from '@layouts/BaseLayout.astro';
import VideoCard from '@components/VideoCard.astro';
import { slugify } from '@utils/slugify';
import { getAllVideos } from '@utils/videoData';

export async function getStaticPaths() {
  const allVideos = await getAllVideos();
  console.log(`[DEBUG_CATEGORY] All videos fetched for categories: ${allVideos.length}`);

  if (allVideos.length === 0) {
    console.error(`[ERROR_CATEGORY] No videos found for categories. Check CSV!`);
    return [];
  }

  const uniqueCategories = [...new Set(allVideos.map((video) => video.category.trim()))];
  console.log(`[DEBUG_CATEGORY] Unique categories found:`, uniqueCategories);

  const paths = [];
  for (const category of uniqueCategories) {
    const categorySlug = slugify(category);
    const videosInCategory = allVideos.filter(video => slugify(video.category) === categorySlug);

    videosInCategory.sort((a, b) => parseInt(b.id) - parseInt(a.id));

    console.log(`[DEBUG_CATEGORY] Category "${category}" (${categorySlug}) has ${videosInCategory.length} videos.`);

    if (videosInCategory.length > 0) {
      paths.push({
        params: { categorySlug: categorySlug },
        props: {
          originalCategoryName: category,
          videos: videosInCategory
        }
      });
    } else {
      console.warn(`[WARN_CATEGORY] Category "${category}" has no videos after filtering. This category page will not be generated.`);
    }
  }
  console.log(`[DEBUG_CATEGORY] Total category paths generated (no pagination): ${paths.length}`);
  return paths;
}

const { categorySlug, originalCategoryName, videos } = Astro.props;

const currentVideos = videos;

const allDomains = new Set<string>();
currentVideos.forEach(video => {
  try {
    allDomains.add(new URL(video.videoUrl).origin);
  } catch (e) {
    console.error(`[ERROR] URL video tidak valid di CSV untuk video ID ${video.id} di kategori ${categorySlug}:`, e);
  }
});
const preconnectDomains = Array.from(allDomains);

const breadcrumbs = [
  { name: 'Beranda', url: '/' },
  { name: 'Kategori', url: '/kategori/' },
  { name: originalCategoryName, url: `/kategori/${categorySlug}/` },
];
---

<Layout
  title={`${originalCategoryName} Video`}
  description={`Jelajahi semua video tentang ${originalCategoryName}.`}
  preconnectDomains={preconnectDomains}
>
  <main class="category-page">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        {breadcrumbs.map((item, index) => (
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {index > 0 && <span class="separator">/</span>}
            {item.url ? (
              <a itemprop="item" href={item.url}>
                <span itemprop="name">{item.name}</span>
              </a>
            ) : (
              <span itemprop="name">{item.name}</span>
            )}
            <meta itemprop="position" content={(index + 1).toString()} />
          </li>
        ))}
      </ol>
    </nav>

    <section class="category-header">
      <h1>Video Kategori: {originalCategoryName}</h1>
      <p>Temukan berbagai video menarik dalam kategori {originalCategoryName}.</p>
    </section>

    <section class="category-videos-section">
      <div class="video-grid">
        {currentVideos.length === 0 ? (
          <p class="no-videos">Belum ada video yang tersedia dalam kategori ini.</p>
        ) : (
          currentVideos.map((video) => (
            <VideoCard video={video} />
          ))
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .category-page {
    max-width: 1200px;
    margin: 30px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .category-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 40px 20px;
    background: linear-gradient(to right, #6c757d, #495057);
    color: white;
    border-radius: 8px;
    box-shadow: var(--shadow-medium);
  }

  .category-header h1 {
    font-size: clamp(2em, 4vw, 3.5em);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .category-header p {
    font-size: clamp(0.9em, 2vw, 1.2em);
    opacity: 0.9;
  }

  .category-videos-section {
    margin-top: 50px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
  }

  .breadcrumb {
    margin-bottom: 20px;
    font-size: 0.9em;
    color: #666;
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
  }

  .breadcrumb a {
    color: var(--primary-color);
    text-decoration: none;
    white-space: nowrap;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .separator {
    margin: 0 8px;
    color: #999;
  }

  .no-videos {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1.2em;
    color: #999;
    padding: 50px 0;
  }

  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }
    .category-page {
      padding: 15px;
    }
    .category-header {
      padding: 30px 15px;
    }
  }

  @media (max-width: 480px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>