---
// src/pages/kategori/[categorySlug].astro
import Layout from '@layouts/BaseLayout.astro';
import VideoCard from '@components/VideoCard.astro';
import { slugify } from '@utils/slugify';
import { getAllVideos } from '@utils/videoData';

export async function getStaticPaths() {
  const allVideos = await getAllVideos();

  if (allVideos.length === 0) {
    return [];
  }

  const uniqueCategories = [...new Set(allVideos.map((video) => video.category.trim()))];
  const paths = [];

  for (const category of uniqueCategories) {
    const categorySlug = slugify(category);
    const videosInCategory = allVideos.filter(video => slugify(video.category) === categorySlug);

    videosInCategory.sort((a, b) => parseInt(b.id) - parseInt(a.id));

    if (videosInCategory.length > 0) {
      paths.push({
        params: { categorySlug: categorySlug },
        props: {
          originalCategoryName: category,
          videos: videosInCategory
        }
      });
    }
  }
  return paths;
}

const { categorySlug, originalCategoryName, videos } = Astro.props;

const currentVideos = videos;

const allDomains = new Set<string>();
currentVideos.forEach(video => {
  try {
    allDomains.add(new URL(video.videoUrl).origin);
  } catch (e) {
    console.error(`[ERROR] URL video tidak valid di CSV untuk video ID ${video.id} di kategori ${categorySlug}:`, e);
  }
});
const preconnectDomains = Array.from(allDomains);
---

<Layout
  title={`${originalCategoryName} Video - Portal Video`}
  description={`Jelajahi semua video tentang ${originalCategoryName}.`}
  preconnectDomains={preconnectDomains}
>
  <main class="category-page container">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <a itemprop="item" href="/">
            <span itemprop="name">Beranda</span>
          </a>
          <span class="separator">/</span>
          <meta itemprop="position" content="1" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <a itemprop="item" href="/kategori/">
            <span itemprop="name">Kategori</span>
          </a>
          <span class="separator">/</span>
          <meta itemprop="position" content="2" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <span itemprop="name">{originalCategoryName}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    <section class="category-header">
      <h1>Video Kategori: {originalCategoryName}</h1>
      <p>Temukan berbagai video menarik dalam kategori {originalCategoryName}.</p>
    </section>

    <section class="category-videos-section">
      <div class="video-grid">
        {currentVideos.length === 0 ? (
          <p class="no-videos">Belum ada video yang tersedia dalam kategori ini.</p>
        ) : (
          currentVideos.map((video) => (
            <VideoCard video={video} />
          ))
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .category-page {
    margin: 30px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .category-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 40px 20px;
    background: linear-gradient(to right, var(--secondary-color), #495057);
    color: white;
    border-radius: 8px;
    box-shadow: var(--shadow-medium);
  }

  .category-header h1 {
    font-size: clamp(2em, 4vw, 3.5em);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .category-header p {
    font-size: clamp(0.9em, 2vw, 1.2em);
    opacity: 0.9;
  }

  .category-videos-section {
    margin-top: 50px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
  }

  .no-videos {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1.2em;
    color: #999;
    padding: 50px 0;
  }

  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }
    .category-page {
      padding: 15px;
    }
    .category-header {
      padding: 30px 15px;
    }
  }

  @media (max-width: 480px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>