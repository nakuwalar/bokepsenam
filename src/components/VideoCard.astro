---
import { slugify } from '../utils/slugify';

interface VideoData {
  id: string;
  title: string;
  description: string;
  thumbnail: string;
  duration: string;
  videoUrl: string;
  category: string;
}

interface Props {
  video: VideoData;
}

const { video } = Astro.props;
const videoSlug = slugify(video.title);
const videoUrl = `/${video.id}/${videoSlug}`; // URL ke halaman detail video
---

<a href={videoUrl} class="video-card" itemprop="video" itemscope itemtype="http://schema.org/VideoObject">
  <div class="thumbnail-wrapper">
    <img
      src={video.thumbnail}
      alt={`${video.title}`}
      loading="lazy"
      decoding="async"
      width="320"
      height="180"
      style="aspect-ratio: 16/9; object-fit: cover;"
      itemprop="thumbnailUrl"
    />
    <span class="duration" itemprop="duration" content={`PT${video.duration.replace(':', 'M')}S`}>{video.duration}</span>
    {/* Format duration ke ISO 8601, misal 03:15 -> PT3M15S */}
  </div>
  <h3 class="title" itemprop="name">{video.title}</h3>
  <p class="description" itemprop="description">
    {video.description
      ? video.description.substring(0, 100) + (video.description.length > 100 ? '...' : '')
      : 'Tidak ada deskripsi.'}
  </p>
  <span class="sr-only" itemprop="uploadDate" content={new Date().toISOString()}></span> {/* Tanggal upload, bisa pakai tanggal hari ini atau ambil dari data CSV jika ada */}
  <span class="sr-only" itemprop="embedUrl" content={video.videoUrl}></span>
  <span class="sr-only" itemprop="contentUrl" content={video.videoUrl}></span>
</a>

<style>
  /* Gaya CSS tidak berubah dari sebelumnya */
  .video-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    background-color: white;
  }

  .video-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .thumbnail-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .thumbnail-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .duration {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background-color: rgba(0, 0, 0, 0.75);
    color: white;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 0.85em;
    font-weight: 500;
  }

  .title {
    font-size: 1.2em;
    font-weight: 700;
    margin: 12px 10px 8px;
    line-height: 1.3;
    color: #333;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .description {
    font-size: 0.95em;
    color: #666;
    margin: 0 10px 12px;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
